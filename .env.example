# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/inventory_db"

# Server Configuration
NODE_ENV=development
PORT=3000

# JWT Configuration
# Secret key for signing tokens (use a cryptographically strong 32+ character string in production)
JWT_SECRET="a4e293edad208d258d4f7b537b975d51cb27a5234e15bf8102f2192c2266f27783b47622a30fb27d89bc97a60af7c4e3bac7c30bdc7939f9da72e77b9cd1f665"

# Access token expiry (short-lived)
JWT_EXPIRES_IN=15m

# Refresh token expiry (long-lived)
JWT_REFRESH_EXPIRES_IN=7d

# Optional: Database Connection Pooling (production)
# DATABASE_POOL_MIN=5
# DATABASE_POOL_MAX=20

# Optional: Logging
# LOG_LEVEL=info

# Optional: Error Tracking (e.g., Sentry)
# SENTRY_DSN=https://your-sentry-dsn
