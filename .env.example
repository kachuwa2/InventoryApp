# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/inventory_db"

# Server Configuration
NODE_ENV=development
PORT=3000

# JWT Configuration
# Secret key for signing tokens (use a cryptographically strong 32+ character string in production)
JWT_SECRET="your-super-secret-key-change-this-in-production-min-32-chars"

# Access token expiry (short-lived)
JWT_EXPIRES_IN=15m

# Refresh token expiry (long-lived)
JWT_REFRESH_EXPIRES_IN=7d

# Optional: Database Connection Pooling (production)
# DATABASE_POOL_MIN=5
# DATABASE_POOL_MAX=20

# Optional: Logging
# LOG_LEVEL=info

# Optional: Error Tracking (e.g., Sentry)
# SENTRY_DSN=https://your-sentry-dsn
