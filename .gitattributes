# Auto detect text files and normalize line endings to LF
* text=auto

# TypeScript and JavaScript files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files (don't touch line endings)
*.db binary
*.sqlite binary
*.wasm binary
