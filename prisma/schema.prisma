generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  manager
  cashier
  warehouse
  viewer
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(cashier)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  auditLogs    AuditLog[]

    // A user can be responsible for many price changes
  priceChanges ProductPriceHistory[]

  stockMovements StockMovement[]

  @@map("users")
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  action      String
  tableName   String?   @map("table_name")
  recordId    String?   @map("record_id")
  beforeState Json?     @map("before_state")
  afterState  Json?     @map("after_state")
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// CATEGORIES
// A category can have a parent category, making
// this a tree structure. For example:
// Food → Grains → Rice
// The parent_id points back to the same table —
// this is called a self-referencing relation.
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?

  // Self-referencing relation — a category can
  // belong to another category (its parent)
  parentId    String?    @map("parent_id")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  // A category can have many products
  products    Product[]

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  @@map("categories")
}

// ─────────────────────────────────────────────
// SUPPLIERS
// The companies or people you buy stock from.
// Credit limit is how much you can owe them
// before they stop supplying you.
// ─────────────────────────────────────────────

model Supplier {
  id            String     @id @default(uuid())
  name          String
  contactPerson String?    @map("contact_person")
  phone         String?
  email         String?
  address       String?

  // How much credit this supplier extends to us.
  // Stored as Decimal, never Float — floats are
  // imprecise for money (0.1 + 0.2 = 0.30000000004)
  creditLimit   Decimal    @default(0) @map("credit_limit") @db.Decimal(12, 2)

  // A supplier can supply many products
  products      Product[]

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  @@map("suppliers")
}

// ─────────────────────────────────────────────
// PRODUCTS
// The core of the entire system. Every other
// module — inventory, sales, purchases — 
// references products.
// ─────────────────────────────────────────────

model Product {
  id           String    @id @default(uuid())
  name         String
  
  // SKU = Stock Keeping Unit. Your internal code.
  // e.g. "RIC-001". Must be unique across all products.

  sku          String    @unique

  // The barcode string — what a scanner reads.
  // e.g. "5012345678900". The actual barcode IMAGE
  // is generated on demand, never stored in the DB.

  barcode      String?   @unique

  description  String?
  unit         String    @default("piece") // e.g. piece, kg, litre, box

  // When stock falls to this level, the system
  // alerts the manager to reorder

  reorderPoint Decimal   @default(0) @map("reorder_point") @db.Decimal(10, 2)

  // Foreign keys — every product must belong
  // to exactly one category and one supplier
  
  categoryId   String    @map("category_id")
  category     Category  @relation(fields: [categoryId], references: [id])

  supplierId   String    @map("supplier_id")
  supplier     Supplier  @relation(fields: [supplierId], references: [id])

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

   // A product can have many price history records
  priceHistory ProductPriceHistory[]

  stockMovements StockMovement[]

  @@map("products")
}

// ─────────────────────────────────────────────────────────
// PRODUCT PRICE HISTORY
// This table is APPEND ONLY. When a price changes, we
// INSERT a new row — we never UPDATE an existing one.
// This gives us a complete timeline of every price change
// for every product, who made it, and when it took effect.
// ─────────────────────────────────────────────────────────

model ProductPriceHistory {
  id        String   @id @default(uuid())

  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])

  // The three prices we track for every product.
  // Decimal(12,2) means up to 12 digits total, 2 after
  // the decimal point. This stores money safely in PostgreSQL
  // without the floating point errors you get with Float.
  costPrice      Decimal @map("cost_price")      @db.Decimal(12, 2)
  retailPrice    Decimal @map("retail_price")    @db.Decimal(12, 2)
  wholesalePrice Decimal @map("wholesale_price") @db.Decimal(12, 2)

  // Who changed the price and when it became active.
  // This is what makes the history traceable.
  changedById  String   @map("changed_by_id")
  changedBy    User     @relation(fields: [changedById], references: [id])
  effectiveFrom DateTime @default(now()) @map("effective_from")

  note String? // optional reason for the price change

  @@map("product_price_history")
}

// ─────────────────────────────────────────────────────────
// STOCK MOVEMENTS — THE LEDGER
// This table is the heart of the inventory system.
// Every single time stock moves — in or out — for any
// reason, a new row is inserted here. Rows are NEVER
// updated or deleted. This is an append-only ledger.
//
// Current stock for any product is always computed as:
// SUM of all movements for that product where
// positive types (purchase, return_in, adjustment_in)
// are added and negative types (sale, adjustment_out)
// are subtracted.
// ─────────────────────────────────────────────────────────

enum MovementType {
  purchase        // stock came in via a purchase order
  sale            // stock went out via a sale
  adjustment_in   // manual correction — stock added
  adjustment_out  // manual correction — stock removed
  return_in       // customer returned goods — stock back in
  return_out      // we returned goods to supplier — stock out
}

model StockMovement {
  id          String       @id @default(uuid())

  productId   String       @map("product_id")
  product     Product      @relation(fields: [productId], references: [id])

  // Movement type determines if this adds or removes stock.
  // purchase, adjustment_in, return_in → add to stock
  // sale, adjustment_out, return_out   → remove from stock
  type        MovementType

  // Always stored as a POSITIVE number regardless of direction.
  // The type field tells us the direction, not the sign.
  // This makes queries and reports much cleaner.
  quantity    Decimal      @db.Decimal(10, 2)

  // The cost per unit at the time of this movement.
  // Critical for inventory valuation and profit calculations.
  // A frying pan might cost $8.50 today but $9.50 next month.
  // We record what it actually cost at the time of movement.
  unitCost    Decimal?     @map("unit_cost") @db.Decimal(12, 2)

  // Polymorphic reference — this movement can be linked to
  // a purchase order, a sale order, or a manual adjustment.
  // We store the ID and the type of record it points to.
  referenceId   String?    @map("reference_id")
  referenceType String?    @map("reference_type")

  // Why this movement happened — required for adjustments
  notes       String?

  performedById String     @map("performed_by_id")
  performedBy   User       @relation(fields: [performedById], references: [id])

  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("stock_movements")
}